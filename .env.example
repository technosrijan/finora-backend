# ── AI Provider ───────────────────────────────────────────────────────────
GROQ_API_KEY="groq_api_key"
AI_MODEL="openai/gpt-oss-120b"

# ── Database ──────────────────────────────────────────────────────────────
# Local dev (SQLite — auto-created, can change in production):
DATABASE_URL="sqlite:///./finora.db"

# ── Redis (Production Recommended) ────────────────────────────────────────
# Progress tracking and caching backend.
# Local dev: leave empty to use in-memory fallback.
# Production: use Google Cloud Memorystore Redis or Redis Cloud.
# Format: redis://host:port/db or redis://username:password@host:port/db
REDIS_URL=""

# ── Auth ──────────────────────────────────────────────────────────────────
# CRITICAL: Change this to a random 64-character string in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"
JWT_EXPIRY_HOURS=72

# ── CORS ──────────────────────────────────────────────────────────────────
# In production, set to your frontend URL (no trailing slash):
ALLOWED_ORIGINS="http://localhost:5173"

# ── ChromaDB Vector Database ──────────────────────────────────────────────
# Leave empty for local dev (uses local ./chroma_db directory).
# In production, set to your chromadb service URL and port (no https://, no trailing slash):
CHROMA_HOST=""
CHROMA_PORT="8000"

# ── Server ────────────────────────────────────────────────────────────────
ENVIRONMENT="development"
LOG_LEVEL="INFO"

# ── Limits ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_SET=3
MAX_TOKEN_BUDGET_PER_REPORT=500000

# ── Concurrency Tuning ────────────────────────────────────────────────────
# Max concurrent LLM map agents per report (default: 4)
MAX_MAP_CONCURRENCY=4
# Max concurrent LLM calls GLOBALLY across all reports (default: 6)
MAX_GLOBAL_LLM_CONCURRENCY=6
# Max concurrent reports being processed globally (default: 6)
MAX_CONCURRENT_REPORTS=6
# Process pool workers for PDF extraction (default: 3). Set to 1 for single-core dev.
EXTRACTION_WORKERS=3
